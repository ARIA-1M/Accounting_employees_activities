<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AccountingEmployeesActivities.ViewModels.Dialogs"
        x:Class="AccountingEmployeesActivities.Views.Dialogs.CreateTaskDialog"
        Title="Создание задачи"
        Width="520" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        x:CompileBindings="False"
        Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F8FAFC">
        <StackPanel Margin="24" Spacing="16">

            <!-- Заголовок -->
            <Border Background="#E2E8F0"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,16">
                <TextBlock Text="Новая задача"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Название задачи -->
            <TextBlock Text="Название задачи"
                       FontWeight="SemiBold"
                       Foreground="#334155"
                       FontSize="13"/>
            <TextBox Text="{Binding TaskName}"
                     Watermark="Введите название задачи"
                     CornerRadius="8"
                     Height="38"
                     Background="White"/>

            <!-- Описание -->
            <TextBlock Text="Описание"
                       FontWeight="SemiBold"
                       Foreground="#334155"
                       FontSize="13"/>
            <TextBox Text="{Binding TaskDescription}"
                     Watermark="Введите описание"
                     CornerRadius="8"
                     Height="80"
                     Background="White"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <!-- Исполнитель -->
            <TextBlock Text="Исполнитель"
                       FontWeight="SemiBold"
                       Foreground="#334155"
                       FontSize="13"/>
            
            <ComboBox ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                      DisplayMemberBinding="{Binding LastName}"
                      CornerRadius="8"
                      Height="38"
                      Background="White"
                      IsEnabled="{Binding IsBoss}"
                      IsVisible="{Binding IsBoss}"/>

            <Border Background="#F1F5F9"
                    CornerRadius="8"
                    Padding="12"
                    Height="38"
                    IsVisible="{Binding IsEmployee}">
                <TextBlock Text="{Binding SelectedEmployee.LastName}"
                           Foreground="#334155"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Border>

            <Separator Margin="0,8,0,8" Background="#E2E8F0" Height="1"/>

            <!-- Сообщение об ошибке -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#EF4444"
                       IsVisible="{Binding IsErrorVisible}"
                       TextWrapping="Wrap"
                       FontSize="13"
                       FontWeight="SemiBold"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="Отмена"
                        Background="Transparent"
                        Foreground="#64748B"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1.5"
                        Padding="24,10"
                        CornerRadius="30"
                        FontWeight="SemiBold"
                        Command="{Binding CancelCommand}">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#F1F5F9"/>
                        </Style>
                    </Button.Styles>
                </Button>
                <Button Content="Создать"
                        Background="#3B82F6"
                        Foreground="White"
                        Padding="24,10"
                        CornerRadius="30"
                        FontWeight="SemiBold"
                        Command="{Binding CreateCommand}">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2563EB"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>