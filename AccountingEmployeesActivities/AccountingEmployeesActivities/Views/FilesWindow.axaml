<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AccountingEmployeesActivities.Views.FilesWindow"
        Title="Файлы"
        Width="450"
        SizeToContent="Height"
        MinHeight="200"
        MaxHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="White" CornerRadius="16">
	<DockPanel Margin="16">
		<!-- Заголовок с плюсом -->
		<DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
			<TextBlock FontSize="20" FontWeight="Bold" DockPanel.Dock="Left">
				<TextBlock.Text>
					<MultiBinding StringFormat="Файлы: {0}">
						<Binding Path="TaskTitle"/>
					</MultiBinding>
				</TextBlock.Text>
			</TextBlock>
			<Button Content="+"
                    Command="{Binding AddFileCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="Black"
                    DockPanel.Dock="Right"
                    Cursor="Hand"
                    Padding="4,0"
                    ToolTip.Tip="Добавить файл"/>
			<Border Height="1" Background="#E2E8F0" Grid.ColumnSpan="2" Margin="0,8,0,0" DockPanel.Dock="Bottom"/>
		</DockPanel>

		<!-- Список файлов -->
		<ListBox ItemsSource="{Binding Files}"
                 DockPanel.Dock="Top"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 MaxHeight="350"
                 Background="Transparent"
                 BorderThickness="0">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<!-- Контейнер для файла -->
					<Border Background="Transparent" Padding="8,6" CornerRadius="8">
						<DockPanel>
							<!-- Кнопка удаления (справа) -->
							<Button Content="✕"
                                    Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    Foreground="#E53E3E"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Cursor="Hand"
                                    DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    ToolTip.Tip="Удалить файл">
								<Button.Styles>
									<Style Selector="Button:pointerover">
										<Setter Property="Foreground" Value="#C53030"/>
										<Setter Property="Background" Value="#FED7D7"/>
									</Style>
								</Button.Styles>
							</Button>
							<!-- Остальная часть (скачивание) -->
							<Button Command="{Binding DataContext.DownloadFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0" Padding="0"
                                    HorizontalContentAlignment="Left"
                                    Cursor="Hand">
								<Button.Styles>
									<Style Selector="Button:pointerover">
										<Setter Property="Background" Value="#F1F5F9"/>
									</Style>
								</Button.Styles>
								<DockPanel>
									<TextBlock Text="📄" FontSize="20" DockPanel.Dock="Left" Margin="0,0,10,0"/>
									<TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center"/>
								</DockPanel>
							</Button>
						</DockPanel>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
			<ListBox.Styles>
				<Style Selector="ListBoxItem">
					<Setter Property="Padding" Value="0"/>
					<Setter Property="Background" Value="Transparent"/>
					<Setter Property="BorderThickness" Value="0"/>
				</Style>
			</ListBox.Styles>
		</ListBox>
	</DockPanel>
</Window>