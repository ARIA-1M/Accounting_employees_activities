<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AccountingEmployeesActivities.Views.MainWindow"
        Title="Учёт деятельности сотрудников"
        Width="900" Height="550"
		WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <TextBlock Text="Добро пожаловать в систему!"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock Name="WelcomeText"
                       FontSize="16"
                       Foreground="#64748b"/>
            <TextBlock Name="RoleText"
                       FontSize="14"
                       Foreground="#64748b"/>
            <Button Name="LogoutButton"
                    Content="Выйти"
                    Width="150"
                    Height="40"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>