<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AccountingEmployeesActivities.Views.Pages.DelegationView"
             x:CompileBindings="False">

	<StackPanel Margin="20" Spacing="16">

		<!-- Заголовок -->
		<Grid ColumnDefinitions="*">
			<TextBlock Grid.Column="0"
                       Text="Делегированные задачи"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
		</Grid>

		<!-- Сетка карточек -->
		<ScrollViewer MaxHeight="500">
			<ItemsControl ItemsSource="{Binding Tasks}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Background="White"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="16"
                                Width="350"
                                Margin="0,0,16,16"
                                Padding="0">
							<Border.Styles>
								<Style Selector="Border:pointerover">
									<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
									<Setter Property="BorderBrush" Value="#CBD5E1"/>
								</Style>
							</Border.Styles>

							<StackPanel>
								<!-- Заголовок карточки -->
								<Border Background="#FAFCFF"
                                        Padding="16,12"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="16,16,0,0">
									<DockPanel>
										<Border Background="Transparent"
                                                BorderBrush="{Binding StatusColor}"
                                                BorderThickness="1"
                                                CornerRadius="30"
                                                Padding="6,2"
                                                DockPanel.Dock="Right"
                                                Margin="10,0,0,0">
											<TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusColor}"
                                                       FontSize="11"
                                                       FontWeight="600"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
										</Border>

										<TextBlock Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="250"/>
									</DockPanel>
								</Border>

								<!-- Тело -->
								<StackPanel Margin="16">
									<TextBlock Text="{Binding Description}"
                                               Foreground="#475569"
                                               FontSize="14"
                                               Margin="0,0,0,12"
                                               TextWrapping="Wrap"/>

									<StackPanel Orientation="Horizontal" Margin="0,0,0,8" Spacing="4">
										<TextBlock Text="{Binding CreatedDate}"
                                                   Foreground="#94A3B8"
                                                   FontSize="11"/>
									</StackPanel>

									<!-- Комментарии -->
									<Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.OpenCommentsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand">
										<Border Background="#F1F5F9"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                CornerRadius="30"
                                                Padding="6,2">
											<TextBlock Text="{Binding CommentsCount, StringFormat='💬 {0}'}"
                                                       FontSize="11"
                                                       FontWeight="500"
                                                       Foreground="#3B82F6"/>
										</Border>
									</Button>

									<!-- Последний комментарий -->
									<Border Background="#F8FAFC"
                                            BorderBrush="#3B82F6"
                                            BorderThickness="3,0,0,0"
                                            CornerRadius="8"
                                            Padding="8,8"
                                            Margin="0,0,0,12"
                                            IsVisible="{Binding LastCommentText}">
										<StackPanel>
											<TextBlock Text="{Binding LastCommentAuthor}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Foreground="#2563EB"/>
											<TextBlock Text="{Binding LastCommentText}"
                                                       FontSize="11"
                                                       Foreground="#475569"/>
										</StackPanel>
									</Border>

									<!-- Файлы -->
									<ItemsControl ItemsSource="{Binding Files}" Margin="0,0,0,12">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Background="#F1F5F9"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="20"
                                                        Padding="6,4"
                                                        Margin="0,0,8,4">
													<TextBlock Text="{Binding}"
                                                               Foreground="#475569"
                                                               FontSize="10"
                                                               FontFamily="Consolas, monospace"/>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<WrapPanel/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
									</ItemsControl>
									<!-- Изменить статус -->
									<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
										<Button Content="Изменить статус"
												Background="Transparent"
												Foreground="#3B82F6"
												BorderBrush="#3B82F6"
												BorderThickness="1"
												CornerRadius="30"
												Padding="12,8"
												FontSize="11"
												FontWeight="500"
												HorizontalContentAlignment="Center"
												VerticalContentAlignment="Center"
												Command="{Binding DataContext.ChangeStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
												CommandParameter="{Binding}">
											<Button.Styles>
												<Style Selector="Button:pointerover">
													<Setter Property="Background" Value="#EEF2FF"/>
													<Setter Property="BorderBrush" Value="#3B82F6"/>
												</Style>
											</Button.Styles>
										</Button>
									<!-- Только просмотр -->
										<Button Content="Файлы"
                                                Background="Transparent"
                                                Foreground="#475569"
                                                BorderBrush="#475569"
                                                BorderThickness="1"
                                                CornerRadius="30"
                                                Padding="12,8"
                                                FontSize="11"
                                                FontWeight="500"
                                                Command="{Binding DataContext.OpenFilesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
											<Button.Styles>
												<Style Selector="Button:pointerover">
													<Setter Property="Background" Value="#F1F5F9"/>
													<Setter Property="BorderBrush" Value="#475569"/>
												</Style>
											</Button.Styles>
										</Button>
									</StackPanel>
								</StackPanel>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<TextBlock Text="{Binding TasksCount}"
                   FontSize="12"
                   Foreground="#94A3B8"
                   HorizontalAlignment="Center"/>

	</StackPanel>
</UserControl>