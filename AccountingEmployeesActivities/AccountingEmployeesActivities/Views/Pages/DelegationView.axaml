<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pagesVm="clr-namespace:AccountingEmployeesActivities.ViewModels.Pages"
             x:Class="AccountingEmployeesActivities.Views.Pages.DelegationView"
             x:DataType="pagesVm:DelegationViewModel">
	<StackPanel Margin="20">
		<TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
		<TextBlock Text="Управление делегированием задач." FontSize="16"/>
	</StackPanel>
</UserControl>