									<TextBlock Text="14.06.2024"
                                               FontSize="10"
                                               Foreground="#94A3B8"/>
								</StackPanel>
							</Border>

							<WrapPanel Margin="0,0,0,12">
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="6,4"
                                        Margin="0,0,8,4">
									<TextBlock Text="queries.sql"
                                               Foreground="#475569"
                                               FontSize="11"
                                               FontFamily="Consolas, monospace"/>
								</Border>
							</WrapPanel>

							<StackPanel Orientation="Horizontal" Spacing="8">
								<Button Content="Изменить статус"
                                        Background="Transparent"
                                        Foreground="#3B82F6"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#EEF2FF"/>
											<Setter Property="BorderBrush" Value="#3B82F6"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Делегировать"
                                        Background="Transparent"
                                        Foreground="#FF6F00"
                                        BorderBrush="#FF6F00"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#FFF3E0"/>
											<Setter Property="BorderBrush" Value="#FF6F00"/>
