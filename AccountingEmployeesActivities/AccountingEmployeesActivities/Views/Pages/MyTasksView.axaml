							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- КАРТОЧКА 5: В РАБОТЕ -->
				<Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="16"
                        Width="340"
                        Margin="0,0,16,16"
                        Padding="0">
					<Border.Styles>
						<Style Selector="Border:pointerover">
							<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
							<Setter Property="BorderBrush" Value="#CBD5E1"/>
						</Style>
					</Border.Styles>
					<StackPanel>
						<Border Background="#FAFCFF"
                                Padding="16,12"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
