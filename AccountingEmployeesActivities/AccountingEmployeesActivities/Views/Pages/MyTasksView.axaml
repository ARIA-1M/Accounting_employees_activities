<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AccountingEmployeesActivities.Views.Pages.MyTasksView"
             x:CompileBindings="False">

	<StackPanel Margin="20" Spacing="16">

		<!-- Верхняя панель -->
		<Grid ColumnDefinitions="*, Auto">
			<TextBlock Grid.Column="0"
                       Text="Мои задачи"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

			<Button Grid.Column="1"
                    Content="+ Создать задачу"
                    Background="#3B82F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Padding="16,10"
                    CornerRadius="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>
		</Grid>

		<!-- Фильтры -->
		<Border Background="White"
                CornerRadius="8"
                Padding="12"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
			<StackPanel Spacing="8">
				<Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, *, Auto">

					<!-- Статус: -->
					<TextBlock Grid.Column="0"
                               Text="Статус:"
                               FontSize="13"
                               FontWeight="500"
                               Foreground="#475569"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

					<!-- Статус (выбор) -->
					<ComboBox Grid.Column="1"
                              Height="32"
                              Margin="0,0,12,0"
                              MinWidth="120">
						<ComboBoxItem>Все статусы</ComboBoxItem>
						<ComboBoxItem>Новая</ComboBoxItem>
						<ComboBoxItem>В работе</ComboBoxItem>
						<ComboBoxItem>Ожидание</ComboBoxItem>
					</ComboBox>

					<!-- С -->
					<TextBlock Grid.Column="2"
                               Text="С"
                               FontSize="13"
                               FontWeight="500"
                               Foreground="#475569"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

					<!-- Дата С -->
					<TextBox Grid.Column="3"
                             Height="32"
                             Width="130"
                             Margin="0,0,12,0"
                             Watermark="дд.мм.гггг"/>

					<!-- По -->
					<TextBlock Grid.Column="4"
                               Text="По"
                               FontSize="13"
                               FontWeight="500"
                               Foreground="#475569"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

					<!-- Дата ПО -->
					<TextBox Grid.Column="5"
                             Height="32"
                             Width="130"
                             Margin="0,0,12,0"
                             Watermark="дд.мм.гггг"/>

					<!-- Пустая колонка (растягивается) -->
					<TextBlock Grid.Column="6" Text=""/>

					<!-- Кнопка "Применить" (справа) -->
					<Button Grid.Column="7"
                            Content="Применить"
                            Background="Transparent"
                            Foreground="#3B82F6"
                            BorderBrush="#3B82F6"
                            BorderThickness="2"
                            Padding="16,6"
                            CornerRadius="40"
                            Height="32"
                            HorizontalAlignment="Right"/>

				</Grid>
			</StackPanel>
		</Border>

		<!-- Сетка карточек -->
		<ScrollViewer MaxHeight="500">
			<WrapPanel>

				<!-- КАРТОЧКА 1: В РАБОТЕ -->
				<Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="16"
                        Width="340"
                        Margin="0,0,16,16"
                        Padding="0">
					<Border.Styles>
						<Style Selector="Border:pointerover">
							<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
							<Setter Property="BorderBrush" Value="#CBD5E1"/>
						</Style>
					</Border.Styles>
					<StackPanel>
						<Border Background="#FAFCFF"
                                Padding="16,12"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="16,16,0,0">
							<DockPanel>
								<Border Background="Transparent"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="8,2"
                                        DockPanel.Dock="Right"
                                        Margin="10,0,0,0">
									<TextBlock Text="В РАБОТЕ"
                                               Foreground="#3B82F6"
                                               FontSize="11"
                                               FontWeight="600"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Разработать ER-диаграмму БД"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
							</DockPanel>
						</Border>

						<StackPanel Margin="16">
							<TextBlock Text="Спроектировать структуру базы данных для системы учёта задач."
                                       Foreground="#475569"
                                       FontSize="14"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>

							<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
								<TextBlock Text="Создана: 10.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<TextBlock Text=" | " Foreground="#94A3B8" FontSize="12" Margin="4,0"/>
								<TextBlock Text="Срок: 20.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
									<TextBlock Text="💬 1"
                                               FontSize="11"
                                               FontWeight="500"
                                               Foreground="#3B82F6"/>
								</Border>
							</StackPanel>

							<Border Background="#F8FAFC"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="3,0,0,0"
                                    CornerRadius="8"
                                    Padding="8,8"
                                    Margin="0,0,0,12">
								<StackPanel>
									<TextBlock Text="Иванов И. (начальник)"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"/>
									<TextBlock Text="Жду результат до пятницы, это важно..."
                                               FontSize="12"
                                               Foreground="#475569"/>
									<TextBlock Text="11.06.2024"
                                               FontSize="10"
                                               Foreground="#94A3B8"/>
								</StackPanel>
							</Border>

							<WrapPanel Margin="0,0,0,12">
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="6,4"
                                        Margin="0,0,8,4">
									<TextBlock Text="ER_diagram.png"
                                               Foreground="#475569"
                                               FontSize="11"
                                               FontFamily="Consolas, monospace"/>
								</Border>
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="6,4"
                                        Margin="0,0,8,4">
									<TextBlock Text="schema.sql"
                                               Foreground="#475569"
                                               FontSize="11"
                                               FontFamily="Consolas, monospace"/>
								</Border>
							</WrapPanel>

							<StackPanel Orientation="Horizontal" Spacing="8">
								<Button Content="Изменить статус"
                                        Background="Transparent"
                                        Foreground="#3B82F6"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#EEF2FF"/>
											<Setter Property="BorderBrush" Value="#3B82F6"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Делегировать"
                                        Background="Transparent"
                                        Foreground="#FF6F00"
                                        BorderBrush="#FF6F00"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#FFF3E0"/>
											<Setter Property="BorderBrush" Value="#FF6F00"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Файлы"
                                        Background="Transparent"
                                        Foreground="#475569"
                                        BorderBrush="#475569"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#F1F5F9"/>
											<Setter Property="BorderBrush" Value="#475569"/>
										</Style>
									</Button.Styles>
								</Button>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- КАРТОЧКА 2: ОЖИДАНИЕ -->
				<Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="16"
                        Width="340"
                        Margin="0,0,16,16"
                        Padding="0">
					<Border.Styles>
						<Style Selector="Border:pointerover">
							<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
							<Setter Property="BorderBrush" Value="#CBD5E1"/>
						</Style>
					</Border.Styles>
					<StackPanel>
						<Border Background="#FAFCFF"
                                Padding="16,12"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="16,16,0,0">
							<DockPanel>
								<Border Background="Transparent"
                                        BorderBrush="#FF6F00"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="8,2"
                                        DockPanel.Dock="Right"
                                        Margin="10,0,0,0">
									<TextBlock Text="ОЖИДАНИЕ"
                                               Foreground="#FF6F00"
                                               FontSize="11"
                                               FontWeight="600"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Настроить CI/CD"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
							</DockPanel>
						</Border>

						<StackPanel Margin="16">
							<TextBlock Text="Настроить автоматическую сборку и тесты в GitLab."
                                       Foreground="#475569"
                                       FontSize="14"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>

							<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
								<TextBlock Text="Создана: 05.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<TextBlock Text=" | " Foreground="#94A3B8" FontSize="12" Margin="4,0"/>
								<TextBlock Text="Срок: 15.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
									<TextBlock Text="💬 1"
                                               FontSize="11"
                                               FontWeight="500"
                                               Foreground="#3B82F6"/>
								</Border>
							</StackPanel>

							<Border Background="#FFFBEB"
                                    BorderBrush="#FF6F00"
                                    BorderThickness="3,0,0,0"
                                    CornerRadius="8"
                                    Padding="8,8"
                                    Margin="0,0,0,12">
								<StackPanel>
									<TextBlock Text="Алексей С. (сотрудник)"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#FF6F00"/>
									<TextBlock Text="Нет доступа к настройкам репозитория..."
                                               FontSize="12"
                                               Foreground="#475569"/>
									<TextBlock Text="07.06.2024"
                                               FontSize="10"
                                               Foreground="#94A3B8"/>
								</StackPanel>
							</Border>

							<WrapPanel Margin="0,0,0,12">
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="6,4"
                                        Margin="0,0,8,4">
									<TextBlock Text=".gitlab-ci.yml"
                                               Foreground="#475569"
                                               FontSize="11"
                                               FontFamily="Consolas, monospace"/>
								</Border>
							</WrapPanel>

							<StackPanel Orientation="Horizontal" Spacing="8">
								<Button Content="Изменить статус"
                                        Background="Transparent"
                                        Foreground="#3B82F6"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#EEF2FF"/>
											<Setter Property="BorderBrush" Value="#3B82F6"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Делегировать"
                                        Background="Transparent"
                                        Foreground="#FF6F00"
                                        BorderBrush="#FF6F00"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#FFF3E0"/>
											<Setter Property="BorderBrush" Value="#FF6F00"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Файлы"
                                        Background="Transparent"
                                        Foreground="#475569"
                                        BorderBrush="#475569"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#F1F5F9"/>
											<Setter Property="BorderBrush" Value="#475569"/>
										</Style>
									</Button.Styles>
								</Button>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- КАРТОЧКА 3: НОВАЯ -->
				<Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="16"
                        Width="340"
                        Margin="0,0,16,16"
                        Padding="0">
					<Border.Styles>
						<Style Selector="Border:pointerover">
							<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
							<Setter Property="BorderBrush" Value="#CBD5E1"/>
						</Style>
					</Border.Styles>
					<StackPanel>
						<Border Background="#FAFCFF"
                                Padding="16,12"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="16,16,0,0">
							<DockPanel>
								<Border Background="Transparent"
                                        BorderBrush="#475569"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="8,2"
                                        DockPanel.Dock="Right"
                                        Margin="10,0,0,0">
									<TextBlock Text="НОВАЯ"
                                               Foreground="#475569"
                                               FontSize="11"
                                               FontWeight="600"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Провести код-ревью модуля авторизации"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
							</DockPanel>
						</Border>

						<StackPanel Margin="16">
							<TextBlock Text="Проверить уязвимости и соответствие стандартам."
                                       Foreground="#475569"
                                       FontSize="14"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>

							<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
								<TextBlock Text="Создана: 13.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<TextBlock Text=" | " Foreground="#94A3B8" FontSize="12" Margin="4,0"/>
								<TextBlock Text="Срок: 17.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
									<TextBlock Text="💬 1"
                                               FontSize="11"
                                               FontWeight="500"
                                               Foreground="#3B82F6"/>
								</Border>
							</StackPanel>

							<Border Background="#F8FAFC"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="3,0,0,0"
                                    CornerRadius="8"
                                    Padding="8,8"
                                    Margin="0,0,0,12">
								<StackPanel>
									<TextBlock Text="Иванов И. (начальник)"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"/>
									<TextBlock Text="Обрати внимание на хэширование паролей..."
                                               FontSize="12"
                                               Foreground="#475569"/>
									<TextBlock Text="13.06.2024"
                                               FontSize="10"
                                               Foreground="#94A3B8"/>
								</StackPanel>
							</Border>

							<WrapPanel Margin="0,0,0,12">
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="6,4"
                                        Margin="0,0,8,4">
									<TextBlock Text="auth_module.cs"
                                               Foreground="#475569"
                                               FontSize="11"
                                               FontFamily="Consolas, monospace"/>
								</Border>
							</WrapPanel>

							<StackPanel Orientation="Horizontal" Spacing="8">
								<Button Content="Изменить статус"
                                        Background="Transparent"
                                        Foreground="#3B82F6"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#EEF2FF"/>
											<Setter Property="BorderBrush" Value="#3B82F6"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Делегировать"
                                        Background="Transparent"
                                        Foreground="#FF6F00"
                                        BorderBrush="#FF6F00"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#FFF3E0"/>
											<Setter Property="BorderBrush" Value="#FF6F00"/>
										</Style>
									</Button.Styles>
								</Button>
								<Button Content="Файлы"
                                        Background="Transparent"
                                        Foreground="#475569"
                                        BorderBrush="#475569"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="12,6"
                                        FontSize="11"
                                        FontWeight="500"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
									<Button.Styles>
										<Style Selector="Button:pointerover">
											<Setter Property="Background" Value="#F1F5F9"/>
											<Setter Property="BorderBrush" Value="#475569"/>
										</Style>
									</Button.Styles>
								</Button>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- КАРТОЧКА 4: В РАБОТЕ -->
				<Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="16"
                        Width="340"
                        Margin="0,0,16,16"
                        Padding="0">
					<Border.Styles>
						<Style Selector="Border:pointerover">
							<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
							<Setter Property="BorderBrush" Value="#CBD5E1"/>
						</Style>
					</Border.Styles>
					<StackPanel>
						<Border Background="#FAFCFF"
                                Padding="16,12"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,0,0,1"
                                CornerRadius="16,16,0,0">
							<DockPanel>
								<Border Background="Transparent"
                                        BorderBrush="#3B82F6"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="8,2"
                                        DockPanel.Dock="Right"
                                        Margin="10,0,0,0">
									<TextBlock Text="В РАБОТЕ"
                                               Foreground="#3B82F6"
                                               FontSize="11"
                                               FontWeight="600"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="Обновить документацию API"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap"
                                           MaxWidth="200"/>
							</DockPanel>
						</Border>

						<StackPanel Margin="16">
							<TextBlock Text="Добавить описание новых эндпоинтов."
                                       Foreground="#475569"
                                       FontSize="14"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"/>

							<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
								<TextBlock Text="Создана: 12.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<TextBlock Text=" | " Foreground="#94A3B8" FontSize="12" Margin="4,0"/>
								<TextBlock Text="Срок: 22.06.2024" Foreground="#94A3B8" FontSize="12"/>
								<Border Background="#F1F5F9"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
									<TextBlock Text="💬 2"
                                               FontSize="11"
                                               FontWeight="500"
                                               Foreground="#3B82F6"/>
								</Border>
							</StackPanel>

							<Border Background="#F8FAFC"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="3,0,0,0"
                                    CornerRadius="8"
                                    Padding="8,8"
                                    Margin="0,0,0,12">
								<StackPanel>
									<TextBlock Text="Алексей Смирнов"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"/>
									<TextBlock Text="Понял, обновляю"
                                               FontSize="12"
                                               Foreground="#475569"/>
									<TextBlock Text="13.06.2024"
                                               FontSize="10"
                                               Foreground="#94A3B8"/>
								</StackPanel>
							</Border>

							<WrapPanel Margin="0,0,0,12">
