<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pagesVm="clr-namespace:AccountingEmployeesActivities.ViewModels.Pages"
             x:Class="AccountingEmployeesActivities.Views.Pages.TasksView"
             x:CompileBindings="False">

	<StackPanel Margin="20" Spacing="16">

		<!-- Верхняя панель -->
		<Grid ColumnDefinitions="*, Auto">
			<TextBlock Grid.Column="0"
                       Text="Мои задачи"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

			<Button Grid.Column="1"
                    Content="+ Создать задачу"
                    Background="#3B82F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Padding="16,10"
                    CornerRadius="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding CreateTaskCommand}"/>
		</Grid>

		<!-- Фильтры -->
		<Border Background="White"
				CornerRadius="8"
				Padding="12"
				BorderBrush="#E0E0E0"
				BorderThickness="1">
			<StackPanel Spacing="8">
				<Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, *, Auto">

					<!-- Сотрудник: -->
					<TextBlock Grid.Column="0"
							   Text="Сотрудник:"
							   FontSize="13"
							   FontWeight="500"
							   Foreground="#475569"
							   VerticalAlignment="Center"
							   Margin="0,0,8,0"/>

					<!-- Поле сотрудник -->
					<ComboBox Grid.Column="1"
							  Height="32"
							  Margin="0,0,12,0"
							  MinWidth="120"
							  ItemsSource="{Binding Employees}"
							  SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
							  DisplayMemberBinding="{Binding LastName}"/>

					<!-- Статус: -->
					<TextBlock Grid.Column="2"
							   Text="Статус:"
							   FontSize="13"
							   FontWeight="500"
							   Foreground="#475569"
							   VerticalAlignment="Center"
							   Margin="0,0,8,0"/>

					<!-- Поле статус -->
					<ComboBox Grid.Column="3"
							  Height="32"
							  Margin="0,0,12,0"
							  MinWidth="120"
							  ItemsSource="{Binding Statuses}"
							  SelectedItem="{Binding SelectedStatus}"/>

					<!-- С -->
					<TextBlock Grid.Column="4"
							   Text="С"
							   FontSize="13"
							   FontWeight="500"
							   Foreground="#475569"
							   VerticalAlignment="Center"
							   Margin="0,0,6,0"/>

					<!-- Поле "Дата С" -->
					<TextBox Grid.Column="5"
							 Height="32"
							 Width="130"
							 Margin="0,0,12,0"
							 Watermark="дд.мм.гггг"
							 Text="{Binding DateFromText}"/>

					<!-- По -->
					<TextBlock Grid.Column="6"
							   Text="По"
							   FontSize="13"
							   FontWeight="500"
							   Foreground="#475569"
							   VerticalAlignment="Center"
							   Margin="0,0,6,0"/>

					<!-- Поле "Дата По" -->
					<TextBox Grid.Column="7"
							 Height="32"
							 Width="130"
							 Margin="0,0,12,0"
							 Watermark="дд.мм.гггг"
							 Text="{Binding DateToText}"/>

					<!-- Пустая колонка (растягивается) -->
					<TextBlock Grid.Column="8" Text=""/>

					<!-- Кнопка "Применить" -->
					<Button Grid.Column="9"
							Content="Применить"
							Background="Transparent"
							Foreground="#3B82F6"
							BorderBrush="#3B82F6"
							BorderThickness="2"
							Padding="16,6"
							CornerRadius="40"
							Height="32"
							HorizontalAlignment="Right"
							Command="{Binding ApplyFiltersCommand}"/>

				</Grid>
			</StackPanel>
		</Border>

		<!-- Сетка карточек -->
		<ScrollViewer MaxHeight="500">
			<ItemsControl ItemsSource="{Binding Tasks}">
				<!-- Панель для карточек -->
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<!-- Карточка с фиксированой шириной -->
						<Border Background="White"
								BorderBrush="#E2E8F0"
								BorderThickness="1"
								CornerRadius="16"
								Width="350"
								Margin="0,0,16,16"
								Padding="0">
							<Border.Styles>
								<Style Selector="Border:pointerover">
									<Setter Property="BoxShadow" Value="0 8 20 rgba(0,0,0,0.05)"/>
									<Setter Property="BorderBrush" Value="#CBD5E1"/>
								</Style>
							</Border.Styles>
							<StackPanel>

								<!-- Заголовок -->
								<Border Background="#FAFCFF"
										Padding="16,12"
										BorderBrush="#E2E8F0"
										BorderThickness="0,0,0,1"
										CornerRadius="16,16,0,0">
									<DockPanel>
										<Border Background="Transparent"
												BorderBrush="{Binding StatusColor}"
												BorderThickness="1"
												CornerRadius="30"
												Padding="6,2"
												DockPanel.Dock="Right"
												Margin="10,0,0,0">
											<TextBlock Text="{Binding StatusText}"
													   Foreground="{Binding StatusColor}"
													   FontSize="11"
													   FontWeight="600"
													   HorizontalAlignment="Center"
													   VerticalAlignment="Center"/>
										</Border>
										<TextBlock Text="{Binding Title}"
												   FontSize="16"
												   FontWeight="SemiBold"
												   Foreground="#0F172A"
												   TextWrapping="Wrap"
												   MaxWidth="250"/>
									</DockPanel>
								</Border>

								<!-- Тело -->
								<StackPanel Margin="16">
									<TextBlock Text="{Binding Description}"
											   Foreground="#475569"
											   FontSize="14"
											   Margin="0,0,0,12"
											   TextWrapping="Wrap"/>

									<!-- Даты -->
									<StackPanel Orientation="Horizontal" Margin="0,0,0,8" Spacing="4">
										<TextBlock Text="{Binding CreatedDate}"
												   Foreground="#94A3B8"
												   FontSize="11"/>
									</StackPanel>

									<!-- Комментарии (кнопка) -->
									<Button Background="Transparent"
											BorderThickness="0"
											Padding="0"
											Margin="0,0,0,8"
											Command="{Binding DataContext.OpenCommentsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
											CommandParameter="{Binding}"
											Cursor="Hand">
										<Border Background="#F1F5F9"
												BorderBrush="#E2E8F0"
												BorderThickness="1"
												CornerRadius="30"
												Padding="6,2">
											<TextBlock Text="{Binding CommentsCount, StringFormat='💬 {0}'}"
													   FontSize="11"
													   FontWeight="500"
													   Foreground="#3B82F6"/>
										</Border>
									</Button>

									<!-- Последний комментарий (кратко) -->
									<Border Background="#F8FAFC"
											BorderBrush="#3B82F6"
											BorderThickness="3,0,0,0"
											CornerRadius="8"
											Padding="8,8"
											Margin="0,0,0,12"
											IsVisible="{Binding LastCommentText}">
										<StackPanel>
											<TextBlock Text="{Binding LastCommentAuthor}"
													   FontSize="10"
													   FontWeight="Bold"
													   Foreground="#2563EB"/>
											<TextBlock Text="{Binding LastCommentText}"
													   FontSize="11"
													   Foreground="#475569"/>
										</StackPanel>
									</Border>

									<!-- Файлы -->
									<ItemsControl ItemsSource="{Binding Files}" Margin="0,0,0,12">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Background="#F1F5F9"
														BorderBrush="#E2E8F0"
														BorderThickness="1"
														CornerRadius="20"
														Padding="6,4"
														Margin="0,0,8,4">
													<TextBlock Text="{Binding}"
															   Foreground="#475569"
															   FontSize="10"
															   FontFamily="Consolas, monospace"/>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<WrapPanel/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
									</ItemsControl>
									<!-- Кнопки действий -->
									<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
										<!-- Изменить статус -->
										<Button Content="Изменить статус"
												Background="Transparent"
												Foreground="#3B82F6"
												BorderBrush="#3B82F6"
												BorderThickness="1"
												CornerRadius="30"
												Padding="12,8"
												FontSize="11"
												FontWeight="500"
												HorizontalContentAlignment="Center"
												VerticalContentAlignment="Center"
												Command="{Binding DataContext.ChangeStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
												CommandParameter="{Binding}">
											<Button.Styles>
												<Style Selector="Button:pointerover">
													<Setter Property="Background" Value="#EEF2FF"/>
													<Setter Property="BorderBrush" Value="#3B82F6"/>
												</Style>
											</Button.Styles>
										</Button>

										<!-- Файлы -->
										<Button Content="Файлы"
												Background="Transparent"
												Foreground="#475569"
												BorderBrush="#475569"
												BorderThickness="1"
												CornerRadius="30"
												Padding="12,8"
												FontSize="11"
												FontWeight="500"
												HorizontalContentAlignment="Center"
												VerticalContentAlignment="Center"
												Command="{Binding DataContext.OpenFilesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
												CommandParameter="{Binding}">
											<Button.Styles>
												<Style Selector="Button:pointerover">
													<Setter Property="Background" Value="#F1F5F9"/>
													<Setter Property="BorderBrush" Value="#475569"/>
												</Style>
											</Button.Styles>
										</Button>
									</StackPanel>
								</StackPanel>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

		<!-- Подвал -->
		<TextBlock Text="{Binding TasksCount}"
                   FontSize="12"
                   Foreground="#94A3B8"
                   HorizontalAlignment="Center"/>

	</StackPanel>
</UserControl>